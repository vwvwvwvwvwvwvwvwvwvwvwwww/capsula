# Порт сайта (по умолчанию 3333)
# Railway сам задаёт PORT, вручную его там указывать не нужно.
# PORT=3333

# Для Railway Volume:
# 1) создайте Volume и примонтируйте его в /data
# 2) добавьте эти переменные в Railway Variables
DB_PATH=/data/app.db
PRODUCTS_PATH=/data/products.json

# --- Почта (уведомления) ---
#
# Railway Hobby блокирует SMTP (порты 465/587). На Pro используйте SMTP Mail.ru:
# MAIL_TRANSPORT=smtp
# SMTP_USER=kapsula.shop@bk.ru
# SMTP_PASS=пароль_для_внешнего_приложения
# MAIL_FROM=Капсула <kapsula.shop@bk.ru>
# MAIL_TO=kapsula.shop@bk.ru
#
# MAIL_TRANSPORT=smtp — принудительно SMTP, даже если остались UNISENDER_* в Variables.
#
# === Вариант для России (рекомендуется) ===
# UniSender Go — HTTPS, серверы в РФ, работает на Railway Hobby:
# 1) https://go.unisender.ru → регистрация
# 2) Настройки → API-ключ → скопировать
# 3) Подтвердить e-mail отправителя (kapsula.shop@bk.ru)
# UNISENDER_GO_API_KEY=ваш_ключ
# MAIL_FROM=Капсула <kapsula.shop@bk.ru>
# MAIL_TO=kapsula.shop@bk.ru
#
# === Бесплатный UniSender (проще, но нужен список) ===
# 1) https://www.unisender.com → регистрация → API-ключ
# 2) npm run setup-unisender — создаст список и добавит контакты (или создайте список вручную)
# 3) Подтвердить e-mail отправителя в веб-интерфейсе (ссылка из письма UniSender)
# UNISENDER_API_KEY=ваш_ключ
# UNISENDER_LIST_ID=12345678
# UNISENDER_SEED_EMAILS=test@gmail.com,ceoof@inbox.ru
# MAIL_FROM=Капсула <kapsula.shop@bk.ru>
# MAIL_TO=kapsula.shop@bk.ru
#
# Альтернатива: тариф Railway Pro + SMTP Mail.ru
#
# SMTP_USER=you@mail.ru
# SMTP_PASS=пароль_приложения
# MAIL_TO=you@mail.ru
# MAIL_FROM=Капсула <you@mail.ru>
# MAIL_OUTBOX_DIR=/data/mail-outbox
#
# Опционально (если автоопределение не сработало):
# SMTP_PROVIDER=yandex|mailru|gmail|outlook|yahoo|rambler|icloud
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=1
#
# --- Примеры по сервисам ---
#
# Яндекс (@yandex.ru, @ya.ru):
# SMTP_USER=you@yandex.ru
# SMTP_PASS=пароль приложения с id.yandex.ru
#
# Mail.ru (@mail.ru, @bk.ru, @inbox.ru, @list.ru):
# SMTP_USER=you@mail.ru
# SMTP_PASS=пароль для внешнего приложения (mail.ru → Настройки → Безопасность)
#
# Gmail:
# SMTP_USER=you@gmail.com
# SMTP_PASS=app password (нужна 2FA в Google)
#
# Outlook / Hotmail:
# SMTP_USER=you@outlook.com
# SMTP_PASS=пароль Microsoft или пароль приложения

# Админ (при каждом запуске обновляется, если заданы оба значения)
ADMIN_EMAIL=ceoof@inbox.ru
ADMIN_PASSWORD=задайте_надёжный_пароль
