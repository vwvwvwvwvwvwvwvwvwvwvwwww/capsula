# Порт сайта (по умолчанию 3333)
# Railway сам задаёт PORT, вручную его там указывать не нужно.
# PORT=3333

# Для Railway Volume:
# 1) создайте Volume и примонтируйте его в /data
# 2) добавьте эти переменные в Railway Variables
DB_PATH=/data/app.db
PRODUCTS_PATH=/data/products.json

# Почта для уведомлений о предзаказах (любой SMTP).
# Проверка: npm run test-mail
#
# Яндекс (рекомендуется для .ru):
# 1) id.yandex.ru → Безопасность → Пароли приложений → «Почта»
# 2) Яндекс.Почта → Настройки → Почтовые программы → разрешить SMTP
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=you@yandex.ru
# SMTP_PASS=пароль_приложения_16_символов
# MAIL_FROM=Kapsula <you@yandex.ru>
# MAIL_TO=you@yandex.ru
#
# Gmail: включите 2FA и создайте App Password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=your@gmail.com
# SMTP_PASS=app_password
# MAIL_FROM=Kapsula <your@gmail.com>
# MAIL_TO=manager@example.com

# Админ при первом запуске (если в базе нет админа)
# ADMIN_EMAIL=admin@kapsula.local
# ADMIN_PASSWORD=admin123
