# Порт сайта (по умолчанию 3333)
# Railway сам задаёт PORT, вручную его там указывать не нужно.
# PORT=3333

# Для Railway Volume:
# 1) создайте Volume и примонтируйте его в /data
# 2) добавьте эти переменные в Railway Variables
DB_PATH=/data/app.db
PRODUCTS_PATH=/data/products.json

# Почта для уведомлений о предзаказах (скопируйте в .env и заполните)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=your@yandex.ru
SMTP_PASS=пароль_приложения
MAIL_FROM=Капсула <your@yandex.ru>
# Куда дублировать заявки магазину (если пусто — на SMTP_USER)
MAIL_TO=your@yandex.ru

# Админ при первом запуске (если в базе нет админа)
# ADMIN_EMAIL=admin@kapsula.local
# ADMIN_PASSWORD=admin123
