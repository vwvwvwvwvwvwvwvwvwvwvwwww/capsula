# Порт сайта (по умолчанию 3333)
# Railway сам задаёт PORT, вручную его там указывать не нужно.
# PORT=3333

# Для Railway Volume:
# 1) создайте Volume и примонтируйте его в /data
# 2) добавьте эти переменные в Railway Variables
DB_PATH=/data/app.db
PRODUCTS_PATH=/data/products.json

# --- Почта (уведомления о предзаказах) ---
# Минимум для любого сервиса: SMTP_USER + SMTP_PASS + MAIL_TO
# SMTP_HOST подставится автоматически по домену почты.
# Проверка: npm run test-mail → админка → «Отправить тестовое письмо»
#
# SMTP_USER=you@mail.ru
# SMTP_PASS=пароль_приложения
# MAIL_TO=you@mail.ru
# MAIL_FROM=Капсула <you@mail.ru>
# MAIL_OUTBOX_DIR=/data/mail-outbox
#
# Опционально (если автоопределение не сработало):
# SMTP_PROVIDER=yandex|mailru|gmail|outlook|yahoo|rambler|icloud
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=1
#
# --- Примеры по сервисам ---
#
# Яндекс (@yandex.ru, @ya.ru):
# SMTP_USER=you@yandex.ru
# SMTP_PASS=пароль приложения с id.yandex.ru
#
# Mail.ru (@mail.ru, @bk.ru, @inbox.ru, @list.ru):
# SMTP_USER=you@mail.ru
# SMTP_PASS=пароль для внешнего приложения (mail.ru → Настройки → Безопасность)
#
# Gmail:
# SMTP_USER=you@gmail.com
# SMTP_PASS=app password (нужна 2FA в Google)
#
# Outlook / Hotmail:
# SMTP_USER=you@outlook.com
# SMTP_PASS=пароль Microsoft или пароль приложения

# Админ (при каждом запуске обновляется, если заданы оба значения)
ADMIN_EMAIL=ceoof@inbox.ru
ADMIN_PASSWORD=задайте_надёжный_пароль
